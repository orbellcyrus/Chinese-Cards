<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link
        rel="stylesheet"
        href="/css/style.css">
</head>

<body>
    <nav class="navbar">
        <div class="logo">
            MySite
        </div>
        <ul class="navLinks">
            <li><a href="/">Home</a></li>
            <li><a href="/dictionary">Dictionary</a></li>
            <li><a href="/account">Account</a></li>
            <li><a href="/decks">Decks</a></li>
            <li><a href="/create">Create Decks</a></li>
        </ul>
    </nav>

    <div class = accountInfo>
        <h1><%= user.username %></h1>
        <p>email:<%= user.email %></p>
        <P>account created: <%= user.created_at %></P>
        <div class="usersCharacters">
            <h1>
                Known Characters
            </h1>
            <% characters.forEach(character =>{ %>
                <p>
                    <%=character.english %>
                    
                    <%=character.chinese_character%>
                </p>
            <% }) %>
        </div>
    </div>
    


  
</body>
</html>